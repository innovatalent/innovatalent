# ====================================================================
# INNOVA TALENT SAAS - Environment Variables
# Copy to .env and fill in your values
# ====================================================================

# --- App ---
NODE_ENV=production
PORT=4000
APP_URL=https://innovatalentlabs.com
FRONTEND_URL=https://innovatalentlabs.com

# --- Database ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=innovatalent
DB_USER=innovatalent_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# --- JWT ---
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Innova Talent <hola@innovatalentlabs.com>

# --- WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxx

# --- AI (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# --- Admin ---
ADMIN_EMAIL=consulting@innovatalentlabs.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# --- Upload ---
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
